{
  "name": "smart-factory-logger-v2",
  "version": "1.0.1",
  "description": "Smart Factory Logger V2 Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "build": {
    "appId": "com.smartfactory.logger",
    "files": [
      "main.js",
      "package.json",
      "node_modules/**/*",
      "!sf-health-*",
      "!.tmp_*",
      "!_tmp_*",
      "!qa_evidence",
      "!server_stdout.zip",
      "!*.pdf",
      "!*.csv",
      "!tmp_*.bin"
    ],
    "win": {
      "target": "nsis",
      "icon": "backend/assets/icon.ico"
    },
    "asar": true,
    "extraResources": [
      {
        "from": "backend/dist/SmartFactoryBackend.exe",
        "to": "backend/SmartFactoryBackend.exe"
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      }
    ]
  }
}
